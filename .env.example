# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GitHub Gist Configuration for persistent cross-browser/cross-session data storage
# These are passed to backend API endpoints (_NOT_ exposed to frontend)
# GITHUB_GIST_TOKEN: Your GitHub personal access token with gist scope
# Generate at: https://github.com/settings/tokens
# Required permissions: gist (read/write)
GITHUB_GIST_TOKEN="ghp_your_token_here"

# GITHUB_GIST_ID: The ID of your GitHub Gist for data storage
# Create one at: https://gist.github.com (or run: fetch from new gist)
GITHUB_GIST_ID="gist_id_here"

